# Copy this file to .env, then replace all values.

POSTGRES_DB=nakama
POSTGRES_USER=nakama_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Port exposed by Nakama HTTP API (7350 in container)
NAKAMA_HTTP_PORT=7350
# Bind address for Nakama HTTP API (use 127.0.0.1 behind reverse proxy)
NAKAMA_BIND_ADDR=127.0.0.1

# Nakama secrets (minimum 32 chars recommended)
NAKAMA_SERVER_KEY=CHANGE_ME_SERVER_KEY_32_CHARS_MINIMUM
NAKAMA_SESSION_ENCRYPTION_KEY=CHANGE_ME_SESSION_ENCRYPTION_KEY_32_CHARS
NAKAMA_REFRESH_ENCRYPTION_KEY=CHANGE_ME_REFRESH_ENCRYPTION_KEY_32_CHARS

# Nakama admin console credentials
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
NAKAMA_CONSOLE_SIGNING_KEY=CHANGE_ME_CONSOLE_SIGNING_KEY_32_CHARS
NAKAMA_RUNTIME_HTTP_KEY=CHANGE_ME_RUNTIME_HTTP_KEY_32_CHARS
